NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=
KAVERO_API_ORIGIN=
# Explicit deployment profile. Cloud is the default/current behavior.
# local-first is a product-policy selector and does not by itself remove Drive or plan gates.
# Auth/storage envs do not imply the deployment profile.
KAVERO_DEPLOYMENT_PROFILE=cloud
# KAVERO_AUTH_MODE selects the login surface only.
# Optional: blank or invalid values fall back to google.
# google = cloud/default
# password = local/self-host-oriented
# google-password = mixed mode for cloud or local when both Supabase providers are enabled
# For local Supabase password auth, override this to password in your local env.
KAVERO_AUTH_MODE=google
# New writes can use the logical Kavero-managed provider.
# Default/cloud behavior remains unchanged unless this is set to kavero-managed.
KAVERO_STORAGE_PROVIDER=
# Managed backend implementation. Default remains supabase-storage.
# local-filesystem is single-node local/Docker-volume storage.
# For local filesystem managed writes, set:
# KAVERO_STORAGE_PROVIDER=kavero-managed
# KAVERO_MANAGED_STORAGE_BACKEND=local-filesystem
# KAVERO_LOCAL_STORAGE_ROOT=<absolute writable path>
KAVERO_MANAGED_STORAGE_BACKEND=
# Required when KAVERO_MANAGED_STORAGE_BACKEND=local-filesystem.
# Must be an absolute, existing, app-writable directory.
KAVERO_LOCAL_STORAGE_ROOT=

# Server-only model gateway contract for LiteLLM-backed model calls.
# Use pnpm setup for generated local secrets. Do not expose these through NEXT_PUBLIC envs.
KAVERO_MODEL_GATEWAY=
KAVERO_LITELLM_BASE_URL=
KAVERO_LITELLM_API_KEY=
# env-or-user (default), user-required, or env-only.
KAVERO_MODEL_GATEWAY_CREDENTIAL_MODE=env-or-user
LITELLM_MASTER_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=

GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
