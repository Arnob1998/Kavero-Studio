# Copy this file to .env.docker.local or run pnpm setup for your local stack.
# The Docker path runs Kavero plus the minimum repo-owned Supabase services.
# Secret-looking values below are placeholders; pnpm setup generates real local secrets.

KAVERO_APP_PORT=3000
SUPABASE_KONG_PORT=54321

POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-postgres-password
SUPABASE_JWT_SECRET=replace-with-local-jwt-secret
SUPABASE_ANON_KEY=replace-with-local-anon-key

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_INTERNAL_URL=http://supabase-kong:8000
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-local-publishable-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000
KAVERO_API_ORIGIN=http://127.0.0.1:3000

KAVERO_DEPLOYMENT_PROFILE=local-first
KAVERO_AUTH_MODE=password
KAVERO_STORAGE_PROVIDER=kavero-managed
KAVERO_MANAGED_STORAGE_BACKEND=local-filesystem
KAVERO_LOCAL_STORAGE_ROOT=/data/kavero-storage

# Server-only LiteLLM gateway.
# Do not expose LiteLLM values through NEXT_PUBLIC envs.
KAVERO_MODEL_GATEWAY=litellm
KAVERO_LITELLM_BASE_URL=http://litellm:4000
KAVERO_LITELLM_API_KEY=sk-replace-with-kavero-litellm-api-key
KAVERO_LITELLM_ROUTING_SECRET=replace-with-litellm-routing-secret
KAVERO_MODEL_GATEWAY_CREDENTIAL_MODE=env-or-user
LITELLM_MASTER_KEY=sk-replace-with-litellm-master-key
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
AZURE_API_VERSION=
AZURE_DEPLOYMENT_NAME=
AZURE_BASE_MODEL=
OLLAMA_BASE_URL=http://host.docker.internal:11434
