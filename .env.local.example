# Host development env for pnpm dev.
# Copy to .env.local and fill in your local or hosted service values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
KAVERO_API_ORIGIN=http://localhost:3000

# Cloud-style local development uses your configured Supabase project.
KAVERO_DEPLOYMENT_PROFILE=cloud
KAVERO_AUTH_MODE=google

# Optional managed storage override for host development.
KAVERO_STORAGE_PROVIDER=
KAVERO_MANAGED_STORAGE_BACKEND=
KAVERO_LOCAL_STORAGE_ROOT=

# Server-only LiteLLM gateway for host development.
# For the current non-virtual-key setup, keep this equal to LITELLM_MASTER_KEY.
KAVERO_MODEL_GATEWAY=litellm
KAVERO_LITELLM_BASE_URL=http://127.0.0.1:4000
KAVERO_LITELLM_API_KEY=sk-change-me
KAVERO_MODEL_GATEWAY_CREDENTIAL_MODE=env-or-user

# Used by the dev LiteLLM container started with pnpm gateway:up.
LITELLM_MASTER_KEY=sk-change-me
GEMINI_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
